{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/default-image",
      "dest": "/api/default_image.py"
    },
    {
      "src": "/api/default_image",
      "dest": "/api/default_image.py"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.py"
    },
    {
      "src": "/api/process",
      "dest": "/api/process.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "regions": ["sin1"],
  "alias": ["computervision-kelompok5-1.vercel.app"]
}
